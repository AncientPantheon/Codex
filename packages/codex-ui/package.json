{
  "name": "@ancientpantheon/codex-ui",
  "version": "0.0.1",
  "private": true,
  "description": "React/browser interface layer of the Codex family — the DOM-facing package hosting future <CodexProvider>, hooks, and headless components.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AncientPantheon/Codex.git",
    "directory": "packages/codex-ui"
  },
  "license": "UNLICENSED"
}
