{
  "name": "@ancientpantheon/codex-arweave",
  "version": "0.2.0",
  "description": "The Arweave Codex module: the foreignKeys JWK keyring integration, the sibling RSA signer, the upload/library feature, and the Arweave UI tab. Builds on @ancientpantheon/arweave-core + codex-core.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapter": {
      "types": "./dist/adapter/index.d.ts",
      "import": "./dist/adapter/index.js"
    },
    "./keyring": {
      "types": "./dist/keyring/index.d.ts",
      "import": "./dist/keyring/index.js"
    },
    "./library": {
      "types": "./dist/library/index.d.ts",
      "import": "./dist/library/index.js"
    },
    "./panel": {
      "types": "./dist/panel/index.d.ts",
      "import": "./dist/panel/index.js"
    },
    "./address-book": {
      "types": "./dist/address-book/index.d.ts",
      "import": "./dist/address-book/index.js"
    },
    "./connection": {
      "types": "./dist/connection/index.d.ts",
      "import": "./dist/connection/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "lucide-react": ">=0.400.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@ancientpantheon/arweave-core": "*",
    "@ancientpantheon/codex-core": "*",
    "@ancientpantheon/codex-ouronet": "*"
  },
  "devDependencies": {
    "@ancientpantheon/codex-ui": "*",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "esbuild": "^0.25.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.0",
    "lucide-react": "^0.483.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AncientPantheon/Codex.git",
    "directory": "packages/codex-arweave"
  },
  "license": "UNLICENSED"
}
