{
  "name": "@ancientpantheon/codex-playground",
  "version": "0.2.0",
  "private": true,
  "description": "Internal, unpublished Vite + React dev playground for the Codex family — mounts the codex-ouronet shell against the workspace source for hot-reloading manual verification. Never published to any registry.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ancientpantheon/codex-arweave": "*",
    "@ancientpantheon/codex-core": "*",
    "@ancientpantheon/codex-ouronet": "*",
    "@ancientpantheon/codex-ui": "*",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18 || ^19",
    "@types/react-dom": "^18 || ^19",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.0"
  }
}
